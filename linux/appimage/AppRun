#!/usr/bin/env bash
# AppRun — entry point for the FastRepeat AppImage
# Handles first-run input group setup, then launches the binary.

set -euo pipefail

APPDIR="$(dirname "$(readlink -f "$0")")"
BINARY="$APPDIR/usr/bin/fastrepeat"

# ─── Input group check ─────────────────────────────────────────────
# FastRepeat needs read access to /dev/input/* (evdev) and write access
# to /dev/uinput. Both require membership in the 'input' group.

check_input_group() {
    if id -nG "$USER" | grep -qw input; then
        return 0  # already in the group
    fi
    return 1
}

prompt_group_add() {
    # Try zenity first (GNOME), fall back to kdialog (KDE), then terminal
    if command -v zenity &>/dev/null; then
        zenity --question \
            --title="Fast Repeat — First Run Setup" \
            --text="Fast Repeat needs access to input devices.\n\nThis requires adding your user to the <b>input</b> group (one-time setup).\nYou'll need to <b>log out and back in</b> afterward.\n\nAdd yourself to the input group now?" \
            --ok-label="Yes, add me" \
            --cancel-label="Not now" \
            --width=420 2>/dev/null
        return $?
    elif command -v kdialog &>/dev/null; then
        kdialog --yesno "Fast Repeat needs access to input devices.\n\nThis requires adding your user to the 'input' group (one-time setup).\nYou'll need to log out and back in afterward.\n\nAdd yourself to the input group now?" \
            --title "Fast Repeat — First Run Setup" 2>/dev/null
        return $?
    else
        echo ""
        echo "Fast Repeat — First Run Setup"
        echo ""
        echo "FastRepeat needs access to input devices."
        echo "This requires adding your user to the 'input' group."
        echo ""
        read -rp "Add yourself to the input group now? [Y/n]: " answer
        case "$answer" in
            [nN]*) return 1 ;;
            *) return 0 ;;
        esac
    fi
}

do_group_add() {
    # pkexec provides a graphical password prompt (polkit)
    if command -v pkexec &>/dev/null; then
        pkexec usermod -aG input "$USER"
    else
        # Fallback: terminal sudo
        echo "Enter your password to add yourself to the 'input' group:"
        sudo usermod -aG input "$USER"
    fi
}

show_logout_notice() {
    if command -v zenity &>/dev/null; then
        zenity --info \
            --title="Fast Repeat" \
            --text="You've been added to the <b>input</b> group.\n\n<b>Please log out and back in</b> for the change to take effect, then run Fast Repeat again." \
            --width=380 2>/dev/null
    elif command -v kdialog &>/dev/null; then
        kdialog --msgbox "You've been added to the 'input' group.\n\nPlease log out and back in for the change to take effect, then run Fast Repeat again." \
            --title "Fast Repeat" 2>/dev/null
    else
        echo ""
        echo "✓ Added to 'input' group."
        echo "  Please log out and back in, then run Fast Repeat again."
        echo ""
    fi
}

show_skip_notice() {
    if command -v zenity &>/dev/null; then
        zenity --warning \
            --title="Fast Repeat" \
            --text="Fast Repeat may not work without input group access.\n\nTo fix later, run:\n  <tt>sudo usermod -aG input $USER</tt>\nThen log out and back in." \
            --width=380 2>/dev/null
    elif command -v kdialog &>/dev/null; then
        kdialog --sorry "Fast Repeat may not work without input group access.\n\nTo fix later, run:\n  sudo usermod -aG input \$USER\nThen log out and back in." \
            --title "Fast Repeat" 2>/dev/null
    else
        echo ""
        echo "⚠ Fast Repeat may not work without input group access."
        echo "  To fix later: sudo usermod -aG input \$USER"
        echo "  Then log out and back in."
        echo ""
    fi
}

# ─── Main ───────────────────────────────────────────────────────────

if ! check_input_group; then
    if prompt_group_add; then
        if do_group_add; then
            show_logout_notice
            exit 0
        else
            echo "Failed to add to input group." >&2
            show_skip_notice
        fi
    else
        show_skip_notice
    fi
fi

# Launch the app, passing through all arguments
exec "$BINARY" "$@"
